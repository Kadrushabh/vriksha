# Server
PORT=3000
NODE_ENV=production

# MongoDB Atlas
# Get from: https://cloud.mongodb.com → Connect → Drivers
MONGODB_URI=mongodb+srv://kadrushabh_db_user:XZVCYVrllNnmaHJ0@cluster0.qotaoxo.mongodb.net/vriksha?appName=Cluster0

# Razorpay
# Get from: https://dashboard.razorpay.com → Settings → API Keys
RAZORPAY_KEY_ID=rzp_live_xxxxxxxxxxxx
RAZORPAY_KEY_SECRET=xxxxxxxxxxxxxxxxxxxx

# Shiprocket
# Get from: https://app.shiprocket.in → Settings → API
